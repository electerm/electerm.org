section.downloads#downloads
  .container
    .section-header
      h2 #{lang.lang.downloadTitle}
      p #{lang.lang.downloadSubtitle}

    //- Auto-detect OS script
    script.
      function detectOS() {
        var p = navigator.platform.toLowerCase();
        var u = navigator.userAgent.toLowerCase();
        if (p.includes('mac') || u.includes('mac')) return 'mac';
        if (p.includes('win') || u.includes('windows')) return 'windows';
        if (p.includes('linux') || u.includes('linux')) return 'linux';
        if (p.includes('android') || u.includes('android')) return 'android';
        return 'windows';
      }
      function switchTab(os) {
        document.querySelectorAll('.download-tab-btn').forEach(function(b){
          b.classList.toggle('active', b.getAttribute('data-tab')===os);
        });
        document.querySelectorAll('.download-panel').forEach(function(p){
          p.classList.toggle('active', p.getAttribute('data-tab')===os);
        });
      }
      function switchArch(btn, arch) {
        var container = btn.closest('.arch-bar').parentElement;
        container.querySelectorAll('.arch-btn').forEach(function(b){
          b.classList.toggle('active', b.getAttribute('data-arch')===arch);
        });
        container.querySelectorAll('.arch-panel').forEach(function(p){
          p.classList.toggle('active', p.getAttribute('data-arch')===arch);
        });
      }
      function isAndroidDevice() {
        var u = navigator.userAgent.toLowerCase();
        var p = (navigator.platform || '').toLowerCase();
        return p.includes('android') || u.includes('android');
      }
      var qrLibLoaded = false;
      function loadQrLib(cb) {
        if (qrLibLoaded) { cb(); return; }
        if (window.qrcode) { qrLibLoaded = true; cb(); return; }
        var s = document.createElement('script');
        s.src = '#{host}/js/qrcode-generator.min.js';
        s.onload = function() { qrLibLoaded = true; cb(); };
        s.onerror = function() { cb(new Error('Failed to load QR library')); };
        document.head.appendChild(s);
      }
      function showQrModal(url, source) {
        var modal = document.getElementById('androidQrModal');
        var codeEl = document.getElementById('androidQrCode');
        var urlEl = document.getElementById('androidQrUrl');
        var dlEl = document.getElementById('androidQrDownload');
        var srcEl = document.getElementById('androidQrSource');
        if (!modal) return;
        urlEl.textContent = url;
        dlEl.href = url;
        if (srcEl && source) srcEl.textContent = source;
        codeEl.innerHTML = '<div class="android-qr-loading">Generating QR code…</div>';
        modal.classList.add('active');
        modal.setAttribute('aria-hidden', 'false');
        loadQrLib(function(err) {
          if (err) {
            codeEl.innerHTML = '<div class="android-qr-error">Failed to generate QR code</div>';
            return;
          }
          try {
            var qr = qrcode(0, 'M');
            qr.addData(url);
            qr.make();
            codeEl.innerHTML = qr.createSvgTag({
              cellSize: 4,
              margin: 4,
              scalable: true,
              alt: 'QR code for ' + url
            });
          } catch(e) {
            codeEl.innerHTML = '<div class="android-qr-error">Failed to generate QR code</div>';
          }
        });
      }
      function hideQrModal() {
        var modal = document.getElementById('androidQrModal');
        if (modal) {
          modal.classList.remove('active');
          modal.setAttribute('aria-hidden', 'true');
        }
      }
      document.addEventListener('DOMContentLoaded', function(){
        switchTab(detectOS());
        document.querySelectorAll('.download-tab-btn').forEach(function(b){
          b.addEventListener('click', function(){ switchTab(this.getAttribute('data-tab')); });
        });
        document.querySelectorAll('.arch-bar').forEach(function(bar){
          bar.querySelectorAll('.arch-btn').forEach(function(b){
            b.addEventListener('click', function(){ switchArch(this, this.getAttribute('data-arch')); });
          });
        });
        // Android QR modal — desktop only
        if (!isAndroidDevice()) {
          var androidPanel = document.querySelector('.download-panel[data-tab="android"]');
          if (androidPanel) {
            androidPanel.querySelectorAll('.download-card-link').forEach(function(link) {
              link.addEventListener('click', function(e) {
                e.preventDefault();
                showQrModal(this.href, this.textContent.trim());
              });
            });
          }
          var closeBtn = document.getElementById('androidQrClose');
          if (closeBtn) closeBtn.addEventListener('click', hideQrModal);
          var overlay = document.querySelector('.android-qr-overlay');
          if (overlay) overlay.addEventListener('click', hideQrModal);
          document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') hideQrModal();
          });
        }
      });

    mixin dlLinks(obj)
      .download-card-links
        a.download-card-link.primary(href=obj.browser_download_url) GitHub
        a.download-card-link(href=obj.sourceforgeUrl) SourceForge
        a.download-card-link(href='https://mirror.electerm.org/' + obj.browser_download_url) gh-proxy
        a.download-card-link(href=obj.r2Url) R2

    mixin dlCard(obj)
      .download-card
        .download-card-top
          .download-card-name #{obj.name}
          - if (obj.desc)
            .download-card-desc #{obj.desc}
        +dlLinks(obj)

    .download-tabs-bar
      button.download-tab-btn.active(data-tab='windows') Windows
      button.download-tab-btn(data-tab='mac') macOS
      button.download-tab-btn(data-tab='linux') Linux
      button.download-tab-btn(data-tab='android') Android
        sup.beta-tag beta

    //- Windows
    .download-panel.active(data-tab='windows')
      .arch-bar
        button.arch-btn.active(data-arch='x64') x64
        button.arch-btn(data-arch='arm64') ARM64
        - if (assets.windows.win7 && assets.windows.win7.items.length > 0)
          button.arch-btn(data-arch='win7') Windows 7
        button.arch-btn(data-arch='all') All
      .arch-panel.active(data-arch='x64')
        .download-grid
          each obj in assets.windows.x64.items
            +dlCard(obj)
      .arch-panel(data-arch='arm64')
        .download-grid
          each obj in assets.windows.arm64.items
            +dlCard(obj)
      - if (assets.windows.win7 && assets.windows.win7.items.length > 0)
        .arch-panel(data-arch='win7')
          .download-grid
            each obj in assets.windows.win7.items
              +dlCard(obj)
      .arch-panel(data-arch='all')
        .download-grid
          each obj in assets.windows.x64.items
            +dlCard(obj)
          each obj in assets.windows.arm64.items
            +dlCard(obj)
          - if (assets.windows.win7 && assets.windows.win7.items.length > 0)
            each obj in assets.windows.win7.items
              +dlCard(obj)

    //- macOS
    .download-panel(data-tab='mac')
      .download-grid
        each obj in assets.mac.items
          +dlCard(obj)

    //- Linux
    .download-panel(data-tab='linux')
      .arch-bar
        button.arch-btn.active(data-arch='x86_64') x86_64
        - if (assets.linux.x86_64_legacy && assets.linux.x86_64_legacy.items.length > 0)
          button.arch-btn(data-arch='x86_64_legacy') x86_64 Legacy
        button.arch-btn(data-arch='arm64') ARM64
        - if (assets.linux.arm64_legacy && assets.linux.arm64_legacy.items.length > 0)
          button.arch-btn(data-arch='arm64_legacy') ARM64 Legacy
        button.arch-btn(data-arch='armv7') ARMv7
        - if (assets.linux.armv7_legacy && assets.linux.armv7_legacy.items.length > 0)
          button.arch-btn(data-arch='armv7_legacy') ARMv7 Legacy
        button.arch-btn(data-arch='loong64') LoongArch64
        - if (assets.linux.loong64_legacy && assets.linux.loong64_legacy.items.length > 0)
          button.arch-btn(data-arch='loong64_legacy') LoongArch64 Legacy
        button.arch-btn(data-arch='all') All
      .arch-panel.active(data-arch='x86_64')
        .download-grid
          each obj in assets.linux.x86_64.items
            +dlCard(obj)
      - if (assets.linux.x86_64_legacy && assets.linux.x86_64_legacy.items.length > 0)
        .arch-panel(data-arch='x86_64_legacy')
          .download-grid
            each obj in assets.linux.x86_64_legacy.items
              +dlCard(obj)
      .arch-panel(data-arch='arm64')
        .download-grid
          each obj in assets.linux.arm64.items
            +dlCard(obj)
      - if (assets.linux.arm64_legacy && assets.linux.arm64_legacy.items.length > 0)
        .arch-panel(data-arch='arm64_legacy')
          .download-grid
            each obj in assets.linux.arm64_legacy.items
              +dlCard(obj)
      .arch-panel(data-arch='armv7')
        .download-grid
          each obj in assets.linux.armv7.items
            +dlCard(obj)
      - if (assets.linux.armv7_legacy && assets.linux.armv7_legacy.items.length > 0)
        .arch-panel(data-arch='armv7_legacy')
          .download-grid
            each obj in assets.linux.armv7_legacy.items
              +dlCard(obj)
      .arch-panel(data-arch='loong64')
        .download-grid
          each obj in assets.linux.loong64.items
            +dlCard(obj)
      - if (assets.linux.loong64_legacy && assets.linux.loong64_legacy.items.length > 0)
        .arch-panel(data-arch='loong64_legacy')
          .download-grid
            each obj in assets.linux.loong64_legacy.items
              +dlCard(obj)
      .arch-panel(data-arch='all')
        .download-grid
          each obj in assets.linux.x86_64.items
            +dlCard(obj)
          - if (assets.linux.x86_64_legacy && assets.linux.x86_64_legacy.items.length > 0)
            each obj in assets.linux.x86_64_legacy.items
              +dlCard(obj)
          each obj in assets.linux.arm64.items
            +dlCard(obj)
          - if (assets.linux.arm64_legacy && assets.linux.arm64_legacy.items.length > 0)
            each obj in assets.linux.arm64_legacy.items
              +dlCard(obj)
          each obj in assets.linux.armv7.items
            +dlCard(obj)
          - if (assets.linux.armv7_legacy && assets.linux.armv7_legacy.items.length > 0)
            each obj in assets.linux.armv7_legacy.items
              +dlCard(obj)
          each obj in assets.linux.loong64.items
            +dlCard(obj)
          - if (assets.linux.loong64_legacy && assets.linux.loong64_legacy.items.length > 0)
            each obj in assets.linux.loong64_legacy.items
              +dlCard(obj)

    //- Android
    - if (assets.android && assets.android.items.length > 0)
      .download-panel(data-tab='android')
        .download-grid
          each obj in assets.android.items
            +dlCard(obj)

    //- Android QR modal (desktop mode)
    .android-qr-modal#androidQrModal(aria-hidden='true', role='dialog')
      .android-qr-overlay
      .android-qr-dialog
        button.android-qr-close#androidQrClose(type='button', aria-label='Close') &times;
        .android-qr-title Scan to download
        .android-qr-desc
          | Scan the QR code with your phone to download
          | via <span id="androidQrSource">GitHub</span>, or download directly below.
        .android-qr-code#androidQrCode
        .android-qr-url#androidQrUrl
        a.android-qr-download#androidQrDownload Download directly

    .download-more
      a(href='https://github.com/electerm/electerm/releases', target='_blank', rel='noreferrer')
        | #{lang.lang.downloadViewAll}
