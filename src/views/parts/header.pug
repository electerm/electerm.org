header.site-header
  .container.header-inner
    a.header-logo(href='/')
      img(src=host + '/electerm.png', alt='electerm')

    nav.header-nav
      a(href='/about/') #{lang.lang.headerAbout}
      a(href='https://cloud.electerm.org', target='_blank', rel='noreferrer') #{lang.lang.headerElectermOnline}
      a(href=faqUrl) #{lang.lang.headerFaq}
      a(href='/videos/') #{lang.lang.headerVideos}
      a(href='/sponsor-electerm/') #{lang.lang.headerSponsor}
      a.header-github-link(href='https://github.com/electerm/electerm', target='_blank', rel='noreferrer')
        span #{lang.lang.headerGithub}
        if starCount
          span.header-star-badge
            svg.header-star-icon(width='14' height='14' viewBox='0 0 16 16' fill='currentColor')
              path(d='M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25z')
            span= starCount >= 1000 ? (starCount / 1000).toFixed(1).replace(/\.0$/, '') + 'k' : starCount

    .header-actions
      .lang-dropdown
        button.lang-toggle(type='button', onclick='this.parentElement.classList.toggle("open")')
          span.flag #{lang.flag}
          span #{langCode}
          span.arrow ▾
        .lang-menu
          each item in langs
            a(href=item.url)
              span.flag #{item.lang.flag}
              span #{item.lang.name}
      button.mobile-menu-btn(type='button', onclick='document.querySelector(".mobile-nav").classList.toggle("open")')
        svg(width='24' height='24' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2')
          line(x1='3' y1='6' x2='21' y2='6')
          line(x1='3' y1='12' x2='21' y2='12')
          line(x1='3' y1='18' x2='21' y2='18')

nav.mobile-nav
  a(href='#demo') #{lang.lang.headerDemo}
  a(href='/about/') #{lang.lang.headerAbout}
  a(href='https://cloud.electerm.org', target='_blank', rel='noreferrer') #{lang.lang.headerElectermOnline}
  a(href=faqUrl) #{lang.lang.headerFaq}
  a(href='/videos/') #{lang.lang.headerVideos}
  a(href='/sponsor-electerm/') #{lang.lang.headerSponsor}
  a.header-github-link(href='https://github.com/electerm/electerm', target='_blank', rel='noreferrer')
    span #{lang.lang.headerGithub}
    if starCount
      span.header-star-badge
        svg.header-star-icon(width='14' height='14' viewBox='0 0 16 16' fill='currentColor')
          path(d='M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25z')
        span= starCount >= 1000 ? (starCount / 1000).toFixed(1).replace(/\.0$/, '') + 'k' : starCount
  h4(style='padding:16px 0 8px;font-size:0.85rem;color:var(--color-text-secondary)') #{lang.lang.headerLanguages}
  .mobile-lang-list
    each item in langs
      a(href=item.url)
        span.flag #{item.lang.flag}
        span #{item.lang.name}

script.
  document.addEventListener('click', function(e) {
    var dd = document.querySelector('.lang-dropdown');
    if (dd && !dd.contains(e.target)) dd.classList.remove('open');
  })
