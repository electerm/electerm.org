//- Tencent Cloud service showcase
//- Shown when /api/country returns CN (China), OR always on zh-CN locale pages
//- All text in Chinese, links to CPS redirect with promotion content
- var txcps = 'https://cloud.tencent.com/act/cps/redirect?cps_key=71420a6b477a42c1917d811755d8cc4c&from=console&redirect='
.cloud-slider-section#tencent-cloud(style='display:none', data-lang-code=langCode, data-provider='tencent')
  .cloud-slider#tencent-slider
      .cloud-track#tencent-track
        //- Slide 1: 轻量应用服务器 新人特惠
        a.cloud-slide(
          href=txcps + '1079',
          target='_blank', rel='nofollow noreferrer',
          data-slide='1'
        )
          .cloud-slide-content
            .cloud-badge 新人专享
            h3.cloud-title 轻量应用服务器
            p.cloud-desc 4核4G3M 新用户首年仅需 79 元/年，一键开服即刻畅玩
            .cloud-cta
              span 立即选购
              svg.cloud-arrow(width='18', height='18', viewBox='0 0 24 24', fill='none')
                path(d='M5 12h14M13 6l6 6-6 6', stroke='currentColor', stroke-width='2.5', stroke-linecap='round', stroke-linejoin='round')

        //- Slide 2: AI 焕新 · 智启新局
        a.cloud-slide(
          href=txcps + '6351',
          target='_blank', rel='nofollow noreferrer',
          data-slide='2'
        )
          .cloud-slide-content
            .cloud-badge AI 焕新
            h3.cloud-title 语音识别限时特惠
            p.cloud-desc 准确率高，支持多语种、多场景，最低 14.9 元起
            .cloud-cta
              span 了解详情
              svg.cloud-arrow(width='18', height='18', viewBox='0 0 24 24', fill='none')
                path(d='M5 12h14M13 6l6 6-6 6', stroke='currentColor', stroke-width='2.5', stroke-linecap='round', stroke-linejoin='round')

        //- Slide 3: 即时通信 IM 专业版
        a.cloud-slide(
          href=txcps + '1058',
          target='_blank', rel='nofollow noreferrer',
          data-slide='3'
        )
          .cloud-slide-content
            .cloud-badge 爆款推荐
            h3.cloud-title 即时通信 IM 专业版
            p.cloud-desc 首购只要 99.9 元，套餐包低至 5 折，接入 AI 高效构建智能聊天
            .cloud-cta
              span 立即抢购
              svg.cloud-arrow(width='18', height='18', viewBox='0 0 24 24', fill='none')
                path(d='M5 12h14M13 6l6 6-6 6', stroke='currentColor', stroke-width='2.5', stroke-linecap='round', stroke-linejoin='round')

        //- Slide 4: 云产品特惠热卖
        a.cloud-slide(
          href=txcps + '5878',
          target='_blank', rel='nofollow noreferrer',
          data-slide='4'
        )
          .cloud-slide-content
            .cloud-badge 热卖套餐
            h3.cloud-title 云产品特惠热卖
            p.cloud-desc 云服务器、数据库、COS、CDN 全线产品，配置低至 32 元/月起
            .cloud-cta
              span 查看热卖套餐
              svg.cloud-arrow(width='18', height='18', viewBox='0 0 24 24', fill='none')
                path(d='M5 12h14M13 6l6 6-6 6', stroke='currentColor', stroke-width='2.5', stroke-linecap='round', stroke-linejoin='round')

        //- Slide 5: 视频通信一站式方案
        a.cloud-slide(
          href=txcps + '1051',
          target='_blank', rel='nofollow noreferrer',
          data-slide='5'
        )
          .cloud-slide-content
            .cloud-badge 限时优惠
            h3.cloud-title 视频通信爆款 9.9 元起
            p.cloud-desc 覆盖电商、教育、社交娱乐等行业，最快 1 天布局火爆赛道
            .cloud-cta
              span 了解更多
              svg.cloud-arrow(width='18', height='18', viewBox='0 0 24 24', fill='none')
                path(d='M5 12h14M13 6l6 6-6 6', stroke='currentColor', stroke-width='2.5', stroke-linecap='round', stroke-linejoin='round')

      //- Navigation
      button.cloud-nav.cloud-prev#tencent-prev(type='button', aria-label='上一张')
        svg(width='22', height='22', viewBox='0 0 24 24', fill='none')
          path(d='M15 6l-6 6 6 6', stroke='currentColor', stroke-width='2.5', stroke-linecap='round', stroke-linejoin='round')
      button.cloud-nav.cloud-next#tencent-next(type='button', aria-label='下一张')
        svg(width='22', height='22', viewBox='0 0 24 24', fill='none')
          path(d='M9 6l6 6-6 6', stroke='currentColor', stroke-width='2.5', stroke-linecap='round', stroke-linejoin='round')
      .cloud-dots#tencent-dots
