//- Aliyun cloud service showcase
//- Shown when /api/country returns CN (China), OR always on zh-CN locale pages
//- All text in Chinese, links to minisite with 10% discount
- var aliyunUrl = 'https://www.aliyun.com/minisite/goods?userCode=sr98yroe'
.cloud-slider-section#aliyun-cloud(data-lang-code=langCode, data-provider='aliyun')
  .cloud-slider#aliyun-slider
      .cloud-track#aliyun-track
        //- Slide 1
        a.cloud-slide(
          href=aliyunUrl,
          target='_blank', rel='nofollow noreferrer',
          data-slide='1'
        )
          .cloud-slide-content
            .cloud-badge 爆款特惠
            h3.cloud-title 阿里云新人专享
            p.cloud-desc 轻量应用服务器 2核2G，200M峰值带宽，新人低至 1 折
            .cloud-cta
              span 立即领取 10% 折扣
              svg.cloud-arrow(width='18', height='18', viewBox='0 0 24 24', fill='none')
                path(d='M5 12h14M13 6l6 6-6 6', stroke='currentColor', stroke-width='2.5', stroke-linecap='round', stroke-linejoin='round')

        //- Slide 2
        a.cloud-slide(
          href=aliyunUrl,
          target='_blank', rel='nofollow noreferrer',
          data-slide='2'
        )
          .cloud-slide-content
            .cloud-badge AI 降本提效
            h3.cloud-title 旗舰大模型最高直降 88%
            p.cloud-desc 通义千问、DeepSeek、GLM 等 150+ 模型全适用，超值特惠价格直降
            .cloud-cta
              span 享受额外 10% 折扣
              svg.cloud-arrow(width='18', height='18', viewBox='0 0 24 24', fill='none')
                path(d='M5 12h14M13 6l6 6-6 6', stroke='currentColor', stroke-width='2.5', stroke-linecap='round', stroke-linejoin='round')

        //- Slide 3
        a.cloud-slide(
          href=aliyunUrl,
          target='_blank', rel='nofollow noreferrer',
          data-slide='3'
        )
          .cloud-slide-content
            .cloud-badge 限时特惠
            h3.cloud-title Token Plan 直省 55%
            p.cloud-desc 全模型通用节省计划，包季低至 4.5 折，加速 AI 生产力
            .cloud-cta
              span 领取专属 10% 折扣
              svg.cloud-arrow(width='18', height='18', viewBox='0 0 24 24', fill='none')
                path(d='M5 12h14M13 6l6 6-6 6', stroke='currentColor', stroke-width='2.5', stroke-linecap='round', stroke-linejoin='round')

        //- Slide 4
        a.cloud-slide(
          href=aliyunUrl,
          target='_blank', rel='nofollow noreferrer',
          data-slide='4'
        )
          .cloud-slide-content
            .cloud-badge AI 编程
            h3.cloud-title Qoder CN 编程智能体
            p.cloud-desc 开启 AI 编程之旅，个人版 Pro 仅 ¥59/月，企业标准版 ¥99/席位/月
            .cloud-cta
              span 通过链接享 10% 折扣
              svg.cloud-arrow(width='18', height='18', viewBox='0 0 24 24', fill='none')
                path(d='M5 12h14M13 6l6 6-6 6', stroke='currentColor', stroke-width='2.5', stroke-linecap='round', stroke-linejoin='round')

        //- Slide 5
        a.cloud-slide(
          href=aliyunUrl,
          target='_blank', rel='nofollow noreferrer',
          data-slide='5'
        )
          .cloud-slide-content
            .cloud-badge 百万补贴
            h3.cloud-title OPC 创新助力计划
            p.cloud-desc 至高百万 Token 补贴加速 AI 生产力，新老同享最低 1000 元起
            .cloud-cta
              span 立即申请享 10% 折扣
              svg.cloud-arrow(width='18', height='18', viewBox='0 0 24 24', fill='none')
                path(d='M5 12h14M13 6l6 6-6 6', stroke='currentColor', stroke-width='2.5', stroke-linecap='round', stroke-linejoin='round')

      //- Navigation
      button.cloud-nav.cloud-prev#aliyun-prev(type='button', aria-label='上一张')
        svg(width='22', height='22', viewBox='0 0 24 24', fill='none')
          path(d='M15 6l-6 6 6 6', stroke='currentColor', stroke-width='2.5', stroke-linecap='round', stroke-linejoin='round')
      button.cloud-nav.cloud-next#aliyun-next(type='button', aria-label='下一张')
        svg(width='22', height='22', viewBox='0 0 24 24', fill='none')
          path(d='M9 6l6 6-6 6', stroke='currentColor', stroke-width='2.5', stroke-linecap='round', stroke-linejoin='round')
      .cloud-dots#aliyun-dots
