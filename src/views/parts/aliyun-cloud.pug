      //- Dot indicators
      .aliyun-cloud-dots#aliyun-cloud-dots

  //- Slider logic + country detection
  script.
    (function(){
      var slider = document.getElementById('aliyun-cloud-slider');
      if (!slider) return;
      var track = document.getElementById('aliyun-cloud-track');
      var slides = track ? track.children : [];
      var total = slides.length;
      var current = 0;
      var timer = null;
      var DURATION = 5000;

      // Build dot indicators
      var dotsContainer = document.getElementById('aliyun-cloud-dots');
      for (var i = 0; i < total; i++) {
        (function(idx){
          var dot = document.createElement('button');
          dot.type = 'button';
          dot.className = 'aliyun-cloud-dot';
          dot.setAttribute('aria-label', '第 ' + (idx + 1) + ' 张');
          dot.addEventListener('click', function(){ goTo(idx); resetTimer(); });
          dotsContainer.appendChild(dot);
        })(i);
      }
      var dots = dotsContainer.children;

      function update() {
        track.style.transform = 'translateX(-' + (current * 100) + '%)';
        for (var i = 0; i < dots.length; i++) {
          if (dots[i]) dots[i].classList.toggle('active', i === current);
        }
      }

      function goTo(idx) {
        current = (idx + total) % total;
        update();
      }

      function next() { goTo(current + 1); }
      function prev() { goTo(current - 1); }

      function startTimer() {
        stopTimer();
        timer = setInterval(next, DURATION);
      }
      function stopTimer() {
        if (timer) { clearInterval(timer); timer = null; }
      }
      function resetTimer() {
        startTimer();
      }

      document.getElementById('aliyun-cloud-next').addEventListener('click', function(){ next(); resetTimer(); });
      document.getElementById('aliyun-cloud-prev').addEventListener('click', function(){ prev(); resetTimer(); });

      // Pause on hover
      slider.addEventListener('mouseenter', stopTimer);
      slider.addEventListener('mouseleave', startTimer);

      // Touch swipe support
      var touchStartX = 0;
      var touchEndX = 0;
      track.addEventListener('touchstart', function(e){ touchStartX = e.changedTouches[0].screenX; }, { passive: true });
      track.addEventListener('touchend', function(e){
        touchEndX = e.changedTouches[0].screenX;
        var diff = touchStartX - touchEndX;
        if (Math.abs(diff) > 40) {
          if (diff > 0) { next(); } else { prev(); }
          resetTimer();
        }
      }, { passive: true });

      // Show for China visitors, or always on Chinese locale pages (zh-CN)
      var section = document.getElementById('aliyun-cloud');
      var langCodeAttr = section ? (section.getAttribute('data-lang-code') || '') : '';
      var isChinesePage = langCodeAttr === 'zh-CN' || langCodeAttr === 'zh-TW';

      function reveal() {
        // Random starting slide so different visitors see different content
        current = Math.floor(Math.random() * total);
        update();
        if (section) section.style.display = '';
        startTimer();
      }

      if (isChinesePage) {
        // Chinese locale page — always show, skip country check
        reveal();
      } else {
        // Other locales — only show for China visitors
        fetch('/api/country').then(function(r){ return r.json(); }).then(function(d){
          var cc = (d.country || '').toUpperCase();
          if (cc === 'CN') {
            reveal();
          }
        }).catch(function(){ /* hide on error */ });
      }
    })();
