//- Vultr cloud service showcase
//- Get $300 free credit with referral link
//- English text, global audience
- var vultrUrl = 'https://www.vultr.com/?ref=9910448-9J'
.cloud-vultr-banner
  a.cloud-vultr-link(href=vultrUrl, target='_blank', rel='nofollow noreferrer')
    .cloud-vultr-content
      .cloud-vultr-badge 🎉 New Users
      h3.cloud-vultr-title Get $300 Free Credit
      p.cloud-vultr-desc Sign up and receive $300 in free credit to deploy cloud servers, storage, and more — no strings attached
      .cloud-vultr-cta
        span Claim $300 Free
        svg.cloud-arrow(width='18', height='18', viewBox='0 0 24 24', fill='none')
          path(d='M5 12h14M13 6l6 6-6 6', stroke='currentColor', stroke-width='2.5', stroke-linecap='round', stroke-linejoin='round')
